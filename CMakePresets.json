{
  "version": 6,
  "configurePresets": [
    {
      "name": "windows-base",
      "description": "Target Windows with the Visual Studio development environment.",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "installDir": "${sourceDir}/install/${presetName}",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "cl.exe",
        "CMAKE_CXX_COMPILER": "cl.exe",
        "SYNTH_TTF_FONT_PATH": "C:/Windows/Fonts/",
        "SYNTH_ARC_TRAINING_PATH": "E:/Devel/ARC/ARC/data/training/",
        "SYNTH_ARC_PRIZE_PATH": "E:/Devel/ARC/arc-prize-2024/",
        "SYNTH_CONAN_PATH_BASE": "E:/Devel/ARC/conan"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "linux-base",
      "description": "Target Linux with the gcc compiler and ninja build.",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/out/build/${presetName}",
      "installDir": "${sourceDir}/out/install/${presetName}",
      "cacheVariables": {
        "CMAKE_C_COMPILER": "gcc",
        "CMAKE_CXX_COMPILER": "g++",
        "SYNTH_TTF_FONT_PATH": "/home/npeter/devel/",
        "SYNTH_ARC_PRIZE_PATH": "/home/npeter/devel/arc-prize-2024/",
        "SYNTH_CONAN_PATH_BASE": "/home/npeter/devel/conan"
      },
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    },
    {
      "name": "WinDebug",
      "displayName": "Win Debug",
      "description": "Target Windows (64-bit) with the Visual Studio development environment. (Debug)",
      "inherits": "windows-base",
      "architecture": {
        "value": "x64",
        "strategy": "external"
      },
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "WinRelease",
      "displayName": "Win Release",
      "description": "Target Windows (64-bit) with the Visual Studio development environment. (Release)",
      "inherits": "WinDebug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "WinRelWithDebInfo",
      "displayName": "Win RelWithDebInfo",
      "description": "Target Windows (64-bit) with the Visual Studio development environment. (RelWithDebInfo)",
      "inherits": "WinDebug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    }
  ]
}